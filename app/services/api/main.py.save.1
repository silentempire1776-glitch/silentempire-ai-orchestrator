from pydantic import BaseModel
import uuid
from shared.redis_bus import enqueue


class RunPayload(BaseModel):
    task: str


@app.post("/run")
def run_task(payload: RunPayload):

    job_id = str(uuid.uuid4())

    log_event(f"[orchestrator] job {job_id} received")

    enqueue(
        "queue.orchestrator",
        {
            "job_id": job_id,
            "task": payload.task
        }
    )

    return {
        "status": "queued",
        "job_id": job_id
    }


