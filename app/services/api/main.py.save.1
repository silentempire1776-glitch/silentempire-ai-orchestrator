loop = None

# --------------------------------------------------
# LOG STREAM BUFFER
# --------------------------------------------------

log_buffer = []

connected_clients = []

def log_event(message: str):

    print(message)

    log_buffer.append(message)

    global loop

    if loop is None:
        return

    for client in connected_clients:
        try:
            asyncio.run_coroutine_threadsafe(
                client.send_text(message),
                loop
            )
        except Exception:
            pass

